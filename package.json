{
  "name": "skillship",
  "version": "0.1.0",
  "description": "Generate and maintain Claude skills from a SaaS vendor's own API signals — OpenAPI, GraphQL, llms.txt, docs, MCP catalogs.",
  "keywords": [
    "claude",
    "claude-code",
    "claude-skills",
    "skill",
    "anthropic",
    "openapi",
    "graphql",
    "mcp",
    "llms-txt",
    "agent",
    "codegen"
  ],
  "homepage": "https://github.com/firmislabs/skillship",
  "bugs": {
    "url": "https://github.com/firmislabs/skillship/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/firmislabs/skillship.git"
  },
  "author": "Firmis Labs",
  "license": "MIT",
  "type": "module",
  "bin": {
    "skillship": "./dist/cli/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && cp src/graph/schema.sql dist/graph/schema.sql",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "eval:build": "tsc -p tsconfig.eval.json && cp src/graph/schema.sql dist-eval/src/graph/schema.sql",
    "eval": "npm run eval:build && node dist-eval/eval/run.js",
    "eval:compare": "npm run eval:build && node dist-eval/eval/compare.js",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "better-sqlite3": "^11.3.0",
    "commander": "^12.1.0",
    "graphql": "^16.13.2",
    "openapi-types": "^12.1.3",
    "ts-morph": "^28.0.0",
    "xml2js": "^0.6.2",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.4",
    "@types/xml2js": "^0.4.14",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
